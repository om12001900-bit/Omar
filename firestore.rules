rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      // Hardcoded admins based on request info supplied by platform
      return isSignedIn() && (
        request.auth.token.email == "om12001900@gmail.com" ||
        request.auth.token.email == "om12101900@gmail.com" ||
        request.auth.uid == "g2JnHl4iKRdJwjSDUYCdvQAZU0E2" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isStaticAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "om12001900@gmail.com" ||
        request.auth.token.email == "om12101900@gmail.com" ||
        request.auth.uid == "g2JnHl4iKRdJwjSDUYCdvQAZU0E2"
      );
    }

    function isVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return (data.uid == request.auth.uid || isStaticAdmin()) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.createdAt != null;
    }

    function isValidGoal(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['name', 'type', 'category', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidHiea(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidProject(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidBudget(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['total', 'cash', 'digital', 'ownerId', 'updatedAt']) &&
             data.total is number && data.cash is number && data.digital is number;
    }

    function isValidWishlistItem(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['name', 'price', 'isBought', 'ownerId', 'createdAt']) &&
             data.name is string && data.price is number;
    }

    function isValidTransaction(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['type', 'amount', 'category', 'ownerId', 'createdAt']) &&
             data.type in ['income', 'expense'] && data.amount is number;
    }

    function isValidStrategicUpdate(data) {
      return (data.ownerId == request.auth.uid || isStaticAdmin()) &&
             data.keys().hasAll(['title', 'content', 'type', 'entityId', 'entityName', 'ownerId', 'createdAt']) &&
             data.title is string && data.content is string;
    }

    // --- Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaticAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isStaticAdmin()) && isValidUser(incoming());
    }

    match /goals/{goalId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidGoal(incoming());
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isValidGoal(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /hieas/{hieaId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidHiea(incoming());
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isValidHiea(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidProject(incoming());
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isValidProject(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /budgets/{budgetId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidBudget(incoming());
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isValidBudget(incoming()) &&
                    incoming().ownerId == existing().ownerId;
    }

    match /wishlist/{itemId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidWishlistItem(incoming());
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isValidWishlistItem(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isValidTransaction(incoming());
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isStaticAdmin();
    }

    match /conferences/{conferenceId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isVerified();
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isVerified();
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /calendar_events/{eventId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isVerified();
      allow update: if (isOwner(existing().ownerId) || isStaticAdmin()) && isVerified();
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /strategic_updates/{updateId} {
      allow get: if isOwner(existing().ownerId) || isStaticAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaticAdmin());
      allow create: if (isOwner(incoming().ownerId) || isStaticAdmin()) && isVerified() && isValidStrategicUpdate(incoming());
      allow delete: if isOwner(existing().ownerId) || isStaticAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
