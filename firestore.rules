rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // PHASE 3: PRIMITIVE DEFINITIONS
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com'); }
    function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // VALIDATION BLUEPRINT HELPERS
    function isValidHiea(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             (data.get('color', '#2dd4bf') is string && data.get('color', '#2dd4bf').size() <= 10);
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             data.hieaId is string &&
             data.progress is int && data.progress >= 0 && data.progress <= 100;
    }

    function isValidConference(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             data.startDate is string &&
             data.location is string;
    }

    function isValidGoal(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.ownerId == request.auth.uid;
    }

    function isValidCalendarEvent(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             data.date is string &&
             data.startTime is string &&
             (data.get('reminder', 'none') in ['none', '15m', '1h', '1d', '1w']);
    }

    // 2. USER PROFILES
    match /users/{userId} {
      allow read: if isOwner(existing());
      allow write: if isOwner(incoming() || existing());
    }

    // 3. HIEAS
    match /hieas/{hieaId} {
      allow read: if isOwner(existing());
      allow create: if isVerified() && isValidHiea(incoming()) && 
                    incoming().keys().hasAll(['name', 'ownerId', 'createdAt']);
      allow update: if isOwner(existing()) && isValidHiea(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing());
    }

    // 4. GOALS
    match /goals/{goalId} {
      allow read: if isOwner(existing());
      allow create: if isVerified() && isValidGoal(incoming());
      allow update: if isOwner(existing()) && isValidGoal(incoming());
      allow delete: if isOwner(existing());
    }

    // 5. PROJECTS
    match /projects/{projectId} {
      allow read: if isOwner(existing());
      allow create: if isVerified() && isValidProject(incoming());
      allow update: if isOwner(existing()) && isValidProject(incoming());
      allow delete: if isOwner(existing());
    }

    // 6. CONFERENCES
    match /conferences/{confId} {
      allow read: if isOwner(existing());
      allow create: if isVerified() && isValidConference(incoming());
      allow update: if isOwner(existing()) && isValidConference(incoming());
      allow delete: if isOwner(existing());
    }

    // 7. CALENDAR EVENTS
    match /calendar_events/{eventId} {
      allow read: if isOwner(existing());
      allow create: if isVerified() && isValidCalendarEvent(incoming());
      allow update: if isOwner(existing()) && isValidCalendarEvent(incoming());
      allow delete: if isOwner(existing());
    }
  }
}
