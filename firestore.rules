rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!data.keys().contains('email') || (data.email is string && data.email.size() <= 255)) &&
             (!data.keys().contains('phoneNumber') || (data.phoneNumber is string && data.phoneNumber.size() <= 30)) &&
             (!data.keys().contains('bio') || (data.bio is string && data.bio.size() <= 1000)) &&
             (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             data.createdAt != null;
    }

    function isValidGoal(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.type in ['objective', 'target'] &&
             data.category in ['OV9', 'S15'] &&
             (!data.keys().contains('progress') || data.progress is number) &&
             (!data.keys().contains('hieaId') || data.hieaId == '' || isValidId(data.hieaId)) &&
             (!data.keys().contains('startDate') || data.startDate is string) &&
             (!data.keys().contains('endDate') || data.endDate is string) &&
             data.createdAt != null;
    }

    function isValidHiea(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             (!data.keys().contains('color') || data.color is string) &&
             (!data.keys().contains('logoUrl') || data.logoUrl is string) &&
             data.createdAt != null;
    }

    function isValidProject(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.status in ['upcoming', 'in-progress', 'completed'] &&
             data.progress is number &&
             data.progress >= 0 && data.progress <= 100 &&
             (!data.keys().contains('description') || data.description is string) &&
             (!data.keys().contains('startDate') || data.startDate is string) &&
             (!data.keys().contains('endDate') || data.endDate is string) &&
             (!data.keys().contains('hieaId') || data.hieaId == '' || isValidId(data.hieaId)) &&
             (!data.keys().contains('hieaIds') || data.hieaIds is list) &&
             (!data.keys().contains('goalId') || data.goalId == '' || isValidId(data.goalId)) &&
             (!data.keys().contains('tags') || data.tags is list) &&
             (!data.keys().contains('icon') || data.icon is string) &&
             (!data.keys().contains('milestones') || data.milestones is list) &&
             data.createdAt != null;
    }

    function isValidConference(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             (!data.keys().contains('description') || data.description is string) &&
             data.createdAt != null;
    }

    function isValidEvent(data) {
      return data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             (!data.keys().contains('date') || data.date is string) &&
             (!data.keys().contains('startTime') || data.startTime is string) &&
             (!data.keys().contains('endTime') || data.endTime is string) &&
             (!data.keys().contains('description') || data.description is string) &&
             (!data.keys().contains('type') || data.type in ['meeting', 'milestone', 'deadline', 'other']) &&
             (!data.keys().contains('priority') || data.priority in ['low', 'medium', 'high', 'critical']) &&
             data.createdAt != null;
    }

    // --- Resource Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'settings', 'bio']);
    }

    match /goals/{goalId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isOwner(incoming().ownerId) && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isOwner(existing().ownerId) && isValidGoal(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'category', 'progress', 'milestones', 'startDate', 'endDate', 'projectId', 'hieaId', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /hieas/{hieaId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isOwner(incoming().ownerId) && isValidId(hieaId) && isValidHiea(incoming());
      allow update: if isOwner(existing().ownerId) && isValidHiea(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'laws', 'procedures', 'achievements', 'logoUrl', 'color', 'progress', 'goalIds', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isOwner(incoming().ownerId) && isValidProject(incoming());
      allow update: if isOwner(existing().ownerId) &&
                    isValidProject(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'startDate', 'endDate', 'status', 'progress', 'milestones', 'hieaId', 'hieaIds', 'goalId', 'tags', 'icon', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /conferences/{conferenceId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isOwner(incoming().ownerId) && isValidId(conferenceId) && isValidConference(incoming());
      allow update: if isOwner(existing().ownerId) && isValidConference(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'startDate', 'endDate', 'location', 'hieaId', 'projectId', 'goalId', 'description', 'agenda', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);
    }

    match /calendar_events/{eventId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isOwner(incoming().ownerId) && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isOwner(existing().ownerId) && isValidEvent(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'date', 'type', 'priority', 'hieaId', 'projectId', 'isCompleted', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
