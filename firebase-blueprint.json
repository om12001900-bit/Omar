{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user identification, preferences and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastCheckInDate": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "themeColor": { "type": "string" },
            "darkMode": { "type": "boolean" },
            "fontSize": { "type": "string", "enum": ["small", "medium", "large"] },
            "borderRadius": { "type": "string", "enum": ["none", "small", "medium", "full"] },
            "defaultCalendarView": { "type": "string", "enum": ["grid", "agenda"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Strategic goal or target",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["objective", "target"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "hieaId": { "type": "string" },
        "projectId": { "type": "string" },
        "category": { "type": "string", "enum": ["OV9", "S15"] },
        "progress": { "type": "number" },
        "kpiTitle": { "type": "string" },
        "kpiTarget": { "type": "number" },
        "kpiCurrent": { "type": "number" },
        "kpiUnit": { "type": "string" },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "ownerId", "createdAt"]
    },
    "Hiea": {
      "title": "Hiea",
      "description": "Strategic entity/authority",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "laws": { "type": "string" },
        "procedures": { "type": "string" },
        "achievements": { "type": "string" },
        "logoUrl": { "type": "string" },
        "color": { "type": "string" },
        "progress": { "type": "number" },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "PerformanceLog": {
      "title": "Performance Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "number" },
        "note": { "type": "string" },
        "date": { "type": "string" },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Strategic project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["upcoming", "in-progress", "pending_completion", "completed"] },
        "progress": { "type": "number" },
        "hieaId": { "type": "string" },
        "hieaIds": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "subGoals": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "challenges": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredResources": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "icon": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Conference": {
      "title": "Conference",
      "description": "Strategic conference or meeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "hieaId": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "Event on the strategic calendar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["meeting", "milestone", "deadline", "other"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "ownerId": { "type": "string" },
        "hieaId": { "type": "string" },
        "reminder": { "type": "string", "enum": ["none", "15m", "1h", "1d", "1w"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "startTime", "endTime", "ownerId", "createdAt"]
    },
    "StrategicUpdate": {
      "title": "Strategic Update",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Budget": {
      "title": "Budget",
      "description": "General budget with cash and digital breakdown",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "total": { "type": "number" },
        "cash": { "type": "number" },
        "digital": { "type": "number" },
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["total", "ownerId", "updatedAt"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "Product desired to be purchased with price comparison logic",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "isBought": { "type": "boolean" },
        "status": { "type": "string", "enum": ["desire", "bought"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "ownerId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of income or expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string", "enum": ["cash", "digital"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Strategic goals"
    },
    "/hieas/{hieaId}": {
      "schema": "Hiea",
      "description": "Strategic authorities"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Strategic projects"
    },
    "/conferences/{conferenceId}": {
      "schema": "Conference",
      "description": "Strategic conferences"
    },
    "/calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Calendar events"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User local budgets"
    },
    "/wishlist/{itemId}": {
      "schema": "WishlistItem",
      "description": "Shopping wishes"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial logs"
    }
  }
}
