{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user identification, preferences and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastCheckInDate": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "themeColor": { "type": "string" },
            "darkMode": { "type": "boolean" },
            "fontSize": { "type": "string", "enum": ["small", "medium", "large"] },
            "borderRadius": { "type": "string", "enum": ["none", "small", "medium", "full"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Strategic goal or target",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["objective", "target"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "hieaId": { "type": "string" },
        "projectId": { "type": "string" },
        "category": { "type": "string", "enum": ["OV9", "S15"] },
        "progress": { "type": "number" },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "ownerId", "createdAt"]
    },
    "Hiea": {
      "title": "Hiea",
      "description": "Strategic entity/authority",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "laws": { "type": "string" },
        "procedures": { "type": "string" },
        "achievements": { "type": "string" },
        "logoUrl": { "type": "string" },
        "color": { "type": "string" },
        "progress": { "type": "number" },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "PerformanceLog": {
      "title": "Performance Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "number" },
        "note": { "type": "string" },
        "date": { "type": "string" },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Strategic project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["upcoming", "in-progress", "pending_completion", "completed"] },
        "progress": { "type": "number" },
        "hieaId": { "type": "string" },
        "hieaIds": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "performanceLogs": {
          "type": "array",
          "items": { "$ref": "#/definitions/PerformanceLog" }
        },
        "icon": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Conference": {
      "title": "Conference",
      "description": "Strategic conference or meeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "hieaId": { "type": "string" },
        "projectId": { "type": "string" },
        "goalId": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "Event on the strategic calendar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["meeting", "milestone", "deadline", "other"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "ownerId": { "type": "string" },
        "hieaId": { "type": "string" },
        "reminder": { "type": "string", "enum": ["none", "15m", "1h", "1d", "1w"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "startTime", "endTime", "ownerId", "createdAt"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Strategic plan for an entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hieaId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "goals": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "text": { "type": "string" },
                    "completed": { "type": "boolean" }
                  }
                }
              },
              "startDate": { "type": "string", "format": "date" },
              "endDate": { "type": "string", "format": "date" },
              "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] }
            }
          }
        },
        "performanceIndicator": { "type": "number" },
        "progress": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hieaId", "title", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Strategic goals"
    },
    "/hieas/{hieaId}": {
      "schema": "Hiea",
      "description": "Strategic authorities"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Strategic projects"
    },
    "/conferences/{conferenceId}": {
      "schema": "Conference",
      "description": "Strategic conferences"
    },
    "/calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Calendar events"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Entity strategic plans"
    }
  }
}
